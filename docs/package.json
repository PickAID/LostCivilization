        "@mdit/plugin-sub": "^0.24.1",
        "@mdit/plugin-sup": "^0.24.1",
        "@mdit/plugin-tab": "^0.24.1",
        "@shikijs/markdown-it": "^4.0.1",
        "@tresjs/cientos": "^5.5.0",
